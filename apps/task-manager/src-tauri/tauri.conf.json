{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Task Manager",
  "version": "0.1.0",
  "identifier": "com.sequenzia.task-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Task Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Visual task management for SDD pipeline",
    "longDescription": "Task Manager is a desktop application that provides a visual kanban board for managing Spec-Driven Development pipeline tasks. Monitor task execution in real-time, navigate across projects and task groups, view spec lifecycles, and manipulate task state through drag-and-drop.",
    "copyright": "Copyright 2026 Stephen Sequenzia",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      },
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
