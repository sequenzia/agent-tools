{
  "description": "Cross-plugin dependency resolution for cache environments",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/resolve-cross-plugins.sh ${CLAUDE_PLUGIN_ROOT}",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
